# Replicate API for AI image generation
REPLICATE_API_TOKEN="your-replicate-api-token-here"

# Database (optional for storing generated designs)
DATABASE_URL="postgresql://tattoo_ideas:password@localhost:5432/tattoo_ideas?schema=public"

# Application
NODE_ENV="development"
PORT=3000
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Rate Limiting
NEXT_PUBLIC_RATE_LIMIT_PER_HOUR=10

# Analytics (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
NEXT_PUBLIC_POSTHOG_KEY=""

# OpenAI API (for prompt enhancement - optional)
OPENAI_API_KEY=""

# Image Storage (optional)
CLOUDINARY_URL=""
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"