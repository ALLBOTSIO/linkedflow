{
  "name": "tattooideas-platform",
  "version": "1.0.0",
  "description": "AI-powered tattoo discovery and design platform",
  "main": "src/server/index.ts",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "server": "tsx src/server/index.ts",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "type-check": "tsc --noEmit",
    "generate:tattoo": "node scripts/generate-tattoo.js"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@shadcn/ui": "latest",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cors": "^2.8.0",
    "express": "^4.18.0",
    "lucide-react": "^0.575.0",
    "next": "^14.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "replicate": "^0.25.2",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/papaparse": "^5.3.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^1.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.0",
    "prisma": "^5.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
